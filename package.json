{
  "name": "ui-automation-playwright-automationexercise",
  "version": "1.0.0",
  "description": "Automation framework using playwright and Javascript",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:parallel": "playwright test --workers=3",
    "test:headed": "playwright test --headed --workers=3",
    "test:maximized": "playwright test --headed --workers=3",
    "test:chromium": "playwright test --project=chromium",
    "test:list": "playwright test --list",
    "browsers:install": "playwright install",
    "report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/intiser321/ui-automation-playwright-AutomationExercise.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/intiser321/ui-automation-playwright-AutomationExercise/issues"
  },
  "homepage": "https://github.com/intiser321/ui-automation-playwright-AutomationExercise#readme",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-commandline": "^2.41.0",
    "allure-playwright": "^3.9.0"
  }
}
